# NestJS backend URL.
# Dev: http://localhost:3000
# Prod (Vercel): leave empty — Vercel rewrites /api/* via vercel.json
VITE_API_BASE_URL=

VITE_API_PREFIX=
VITE_TENANT_ID=
VITE_AUTH_STORAGE_KEY=
VITE_REQUEST_TIMEOUT_MS=

# Express admin server port (local only — not used by frontend in prod)
ADMIN_SERVER_PORT=4000
CORS_ORIGIN=http://localhost:5173

APP_INSIGHTS_API_KEY=
APP_INSIGHTS_APP_ID=
